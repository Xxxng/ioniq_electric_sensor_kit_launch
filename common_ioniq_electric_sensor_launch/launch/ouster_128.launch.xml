<launch>
  <!-- Params -->
  <arg name="sensor_frame" default="velodyne_top"/>
  <arg name="vehicle_mirror_param_file"/>
  <arg name="container_name" default="ouster_node_container"/>

  <include file="$(find-pkg-share common_ioniq_electric_sensor_launch)/launch/ouster_node_container.launch.py">
    <arg name="frame_id" value="$(var sensor_frame)"/>
    <arg name="vehicle_mirror_param_file" value="$(var vehicle_mirror_param_file)"/>
    <arg name="use_intra_process" value="true"/>
    <arg name="use_multithread" value="true"/>
    <arg name="container_name" value="$(var container_name)"/>
  </include>

</launch>
