<launch>
  <arg name="launch_driver" default="true"/>
  <arg name="multi_usbcam"  default="false"/>

  <!--    common parameters -->
  <arg name="image_0" default="camera0" description="image raw topic name"/>
  <arg name="image_1" default="camera1" description="image raw topic name"/>

  <!--    tensorrt params -->
  <arg name="mode" default="FP32"/>
  <arg name="yolo_type" default="yolox_tiny" description="choose image raw number(0-7)"/>
  <arg name="label_file" default="coco.names" description="yolo label file"/>
  <arg name="gpu_id" default="0" description="choose your gpu id for inference"/>
  <arg name="use_intra_process" default="true"/>
  <arg name="use_multithread" default="true"/>

  <group if="$(var launch_driver)">
    <include file="$(find-pkg-share common_ioniq_sensor_launch)/launch/camera_node_container.launch.py">
      <arg name="mode" value="$(var mode)"/>
      <arg name="input_image" value="$(var image_0)"/>
      <arg name="camera_container_name" value="front_camera_container"/>
      <arg name="yolo_type" value="$(var yolo_type)"/>
      <arg name="label_file" value="$(var label_file)"/>
      <arg name="gpu_id" value="$(var gpu_id)"/>
      <arg name="output_topic" value="camera0/rois0"/>
      <arg name="use_intra_process" value="$(var use_intra_process)"/>
      <arg name="use_multithread" value="$(var use_multithread)"/>
      <arg name="camera_model_param_path" value="$(find-pkg-share ioniq_sensor_kit_launch)/config/camera0.yaml"/>
      <arg name="rorate_config_path" value="$(find-pkg-share ioniq_sensor_kit_launch)/config/camera0_rotate.yaml"/>

    </include>

    <!-- <include file="$(find-pkg-share common_ioniq_sensor_launch)/launch/camera_node_container.launch.py">
      <arg name="mode" value="$(var mode)"/>
      <arg name="input_image" value="$(var image_0)"/>
      <arg name="camera_container_name" value="front_camera_container"/>
      <arg name="yolo_type" value="$(var yolo_type)"/>
      <arg name="label_file" value="$(var label_file)"/>
      <arg name="gpu_id" value="$(var gpu_id)"/>
      <arg name="output_topic" value="camera0/rois0"/>
      <arg name="use_intra_process" value="$(var use_intra_process)"/>
      <arg name="use_multithread" value="$(var use_multithread)"/>
      <arg name="camera_model_param_path" value="$(find-pkg-share ioniq_sensor_kit_launch)/config/camera0.yaml"/>
    </include> -->
  </group>
</launch>
