<launch>
  <group>
    <push-ros-namespace namespace="imu"/>

    <include file="$(find-pkg-share autoware_imu_corrector)/launch/imu_corrector.launch.xml">
      <arg name="input_topic" value="/sensing/imu/imu_raw"/>
      <arg name="output_topic" value="/sensing/imu/imu_data"/>
      <!-- <arg name="param_file" value="$(find-pkg-share individual_params)/config/$(env VEHICLE_ID default)/sample_sensor_kit/imu_corrector.param.yaml"/> -->
    </include>
    
    <include file="$(find-pkg-share autoware_imu_corrector)/launch/gyro_bias_estimator.launch.xml">
      <arg name="input_imu_raw" value="/sensing/imu/imu_raw"/>
      <arg name="input_odom" value="/localization/kinematic_state"/>
      <!-- <arg name="imu_corrector_param_file" value="$(var imu_corrector_param_file)"/> -->
    </include>
  </group>
</launch>
